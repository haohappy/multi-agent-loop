# cc-review configuration
# Source this file or export these variables in your shell profile

# Maximum number of review rounds before stopping
CC_REVIEW_MAX_ROUNDS=5

# Claude Code model (empty = use default)
CC_REVIEW_CLAUDE_MODEL=""

# Codex model for reviews
CC_REVIEW_CODEX_MODEL="o3"

# Where to store session artifacts
CC_REVIEW_OUTPUT_DIR=".cc-review"

# Timeout per CLI call in seconds
CC_REVIEW_TIMEOUT=300

# Debug output
CC_REVIEW_VERBOSE=false
